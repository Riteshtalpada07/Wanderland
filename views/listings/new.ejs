<% layout("/layouts/boilerplate") %>
   <form method="post" action="/listings" novalidate class="needs-validation" >
     <div class="col-8 offset-2">
        <h3>Create a New Listing</h3>
        <div class="mb-3">
           <label for="title" class="form-label">Title: </label>
           <input type="text" name="listing[title]" class="form-control" placeholder="Enter title" required />
           <div class="invalid-feedback">Please enter title</div>
        </div>

       <div class="mb-3">
          <label for="price" class="form-label" >Price (in ₹): </label>
          <input type="text" name="listing[price]"  class="form-control" placeholder="Enter price" required />
          <div class="invalid-feedback">Price should be valid</div>
       </div>
        
       <div class="mb-3">
          <label for="description" class="form-label">Description: </label>
        <textarea name="listing[description]"  class="form-control" placeholder="Enter description" required></textarea>
         <div class="invalid-feedback">Please enter description</div>
       </div>
        
       <div class="mb-3">
           <label for="image" class="form-label">Enter image:</label>
        <input type="text" name="listing[image]" placeholder="Enter image URL/link"  class="form-control"/>
       </div>
       
       <div class="mb-3">
        <label for="location" class="form-label">Location: </label>
        <input type="text" name="listing[location]"  class="form-control" placeholder="Enter location" required />
         <div class="invalid-feedback">Please enter location</div>
       </div>

        <button type="submit" class="btn btn-dark add-btn">ADD</button>
        </div>
   </form> 
